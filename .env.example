# ── OBRIGATÓRIAS ─────────────────────────────────────────────────────────────

# Banco de dados (PostgreSQL async)
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# Claude AI
ANTHROPIC_API_KEY=sk-ant-...

# ── OPCIONAIS — integrações externas ─────────────────────────────────────────

# Jira
JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=you@yourcompany.com
JIRA_API_TOKEN=your_jira_api_token

# Google Calendar
GOOGLE_REFRESH_TOKEN=1//...
GOOGLE_CLIENT_ID=....apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# WhatsApp (Whapi legado)
WHAPI_TOKEN=
WHAPI_API_URL=https://gate.whapi.cloud
PEDRO_PHONE=5521999999999
# Chat ID do grupo Alfred no Whapi (ex: "5521999999999-1234567890@g.us")
# Se vazio, mensagens from_me de grupos são rejeitadas (mais seguro).
ALFRED_WHAPI_CHAT_ID=

# WhatsApp Gateway (whatsapp-web.js)
WA_BRIDGE_SHARED_SECRET=
WA_GATEWAY_URL=

# Modelos Claude (já têm default, só altere se necessário)
# MODEL_FAST=claude-haiku-4-5-20251001
# MODEL_SMART=claude-sonnet-4-6
