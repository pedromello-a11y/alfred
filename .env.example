# ── OBRIGATÓRIAS ─────────────────────────────────────────────────────────────

# Banco de dados (PostgreSQL async)
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# Claude AI
ANTHROPIC_API_KEY=sk-ant-...

# ── OPCIONAIS — integrações externas ─────────────────────────────────────────

# Jira
JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=you@yourcompany.com
JIRA_API_TOKEN=your_jira_api_token

# Google Calendar — OAuth2 (use /auth/google para autorizar via browser)
GOOGLE_CLIENT_ID=....apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
# URL de callback cadastrada no Google Cloud Console (deve bater exatamente)
GOOGLE_REDIRECT_URI=https://seu-app.up.railway.app/auth/google/callback
# Deprecated: refresh_token direto por env var (substituído pelo fluxo OAuth no banco)
# GOOGLE_REFRESH_TOKEN=1//...

# WhatsApp (Whapi legado)
WHAPI_TOKEN=
WHAPI_API_URL=https://gate.whapi.cloud
PEDRO_PHONE=5521999999999
# Chat ID ÚNICO permitido para processar mensagens (grupo Alfred ou DM inbox).
# Formato grupo: "120363XXXXXXXXXX@g.us" | Formato DM: "5521999999999@s.whatsapp.net"
# Se vazio, TODAS as mensagens são processadas (perigoso — configure antes de ir pra produção).
# Dica: com ALLOWED_CHAT_ID vazio, os logs mostram o chat_id de cada mensagem recebida.
ALLOWED_CHAT_ID=
# Chat ID do grupo Alfred no Whapi legado (ex: "5521999999999-1234567890@g.us")
ALFRED_WHAPI_CHAT_ID=

# ── ADMIN ─────────────────────────────────────────────────────────────────────
# Chave para endpoints destrutivos (POST /admin/dumps/clear-all, etc.)
ADMIN_SECRET_KEY=

# WhatsApp Gateway (whatsapp-web.js)
WA_BRIDGE_SHARED_SECRET=
WA_GATEWAY_URL=

# Modelos Claude (já têm default, só altere se necessário)
# MODEL_FAST=claude-haiku-4-5-20251001
# MODEL_SMART=claude-sonnet-4-6
